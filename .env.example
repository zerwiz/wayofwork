# Way of Work — Environment Configuration

# REQUIRED in production: JWT signing secret (generate with: openssl rand -hex 32)
# WOP_AUTH_SECRET=change-me-to-a-random-secret

# Workspace root (defaults to server working directory)
# WOP_WORKSPACE=/path/to/project

# Server port
WOP_SERVER_PORT=3333

# LLM provider: ollama (default) or openrouter
WOP_LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# OpenRouter (set WOP_LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openrouter/auto

# Enable interactive terminal (host shell — trusted networks only)
# WOP_ALLOW_TERMINAL=1

# Optional system prompt
# WOP_SYSTEM_PROMPT=You are a helpful assistant.

# Claw .claw/ host root (parent of .claw/ directory)
# WOP_CLAW_HOST_ROOT=/path/to/claw/checkout

# Orchestrator tools (read/write/grep/ls) — default on
# WOP_ORCHESTRATOR_TOOLS=1
# WOP_ORCHESTRATOR_BASH=0

# Chat engine: auto (default), bundled/bun, or pi
# WOP_CHAT_ENGINE=auto
# WOP_PI_BINARY=/path/to/pi

# Claw bot channels (Telegram, WhatsApp)
# Copy tokens from the Admin Console or set them here.
# WOP_TELEGRAM_BOT_TOKEN=
# WOP_TELEGRAM_BOT_USERNAME=MyClawBot

# WhatsApp Cloud API
# WOP_WHATSAPP_PHONE_NUMBER_ID=
# WOP_WHATSAPP_ACCESS_TOKEN=
# WOP_WHATSAPP_BUSINESS_ACCOUNT_ID=

# Public URL (for Telegram webhooks, notification links, ngrok)
# WOP_PUBLIC_URL=https://your-domain.ngrok-free.dev

# ngrok tunnel (auto-start on boot when WOP_NGROK_DOMAIN is set)
# WOP_NGROK_DOMAIN=your-domain.ngrok-free.dev
# WOP_NGROK_BINARY=/usr/local/bin/ngrok
# WOP_NGROK_WEB_ADDR=127.0.0.1:4040
# WOP_ALLOW_NGROK_SPAWN=1

# Tunnel Basic Auth gate markers (comma-separated host patterns that trigger auth)
# WOP_TUNNEL_GATE_HOST_MARKERS=ngrok-free.dev,ngrok.io

# SMTP Email (for email_send tool and inbound email replies)
# WOP_SMTP_HOST=smtp.example.com
# WOP_SMTP_PORT=587
# WOP_SMTP_USER=myuser
# WOP_SMTP_PASS=mypassword
# WOP_SMTP_FROM=noreply@example.com
# WOP_SMTP_FROM_NAME=Way of Work
